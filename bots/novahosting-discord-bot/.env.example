# Discord bot token from the Discord Developer Portal
DISCORD_TOKEN=

# Discord application (client) ID, used to register slash commands
DISCORD_CLIENT_ID=

# Optional: restrict slash command registration to a single guild for instant
# updates during development. Leave blank to register commands globally
# (global registration can take up to an hour to propagate).
DISCORD_GUILD_ID=

# Base URL of your FeatherPanel installation, e.g. https://panel.novahosting.com
FEATHERPANEL_URL=

# FeatherPanel API key/token with permission to manage users, servers, and billing
FEATHERPANEL_API_KEY=

# Discord role ID allowed to run staff-only commands
STAFF_ROLE_ID=

# Discord channel ID where action logs (bans, credit changes, server actions, etc.) are posted
LOG_CHANNEL_ID=
